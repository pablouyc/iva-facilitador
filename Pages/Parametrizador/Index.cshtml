@page "/Parametrizador"
@model IvaFacilitador.Pages.Parametrizador.IndexModel
@{
    ViewData["Title"] = "Parametrización";
    var titleName = string.IsNullOrWhiteSpace(Model.CompanyName) ? "—" : Model.CompanyName;
}
<div class="container my-4">
  <div class="row">
    <div class="col-12 col-lg-10">
      <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
          <h5 class="mb-0">PARAMETRIZACIÓN @titleName</h5>
          <span class="text-muted small">RealmId: @Model.RealmId</span>
        </div>
        <div class="card-body">
          <p class="text-muted">Completa la información para preparar el IVA de Costa Rica.</p>

          <form method="post" asp-antiforgery="true">
            <input type="hidden" asp-for="RealmId" />
            <div class="mb-3">
              <label class="form-label fw-semibold">Empresa (QBO)</label>
              <input class="form-control" value="@Model.CompanyName" disabled />
            </div>

            <div class="alert alert-info mb-4">
              <div class="fw-semibold">Próximo paso</div>
              Vamos a ir agregando cada sección (Tarifas de ventas, Datáfonos, MEIC/MAG, Prorrata, Cuentas IVA, etc.).
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary" formaction="?handler=Save">Guardar</button>
              <button type="submit" class="btn btn-outline-danger" formaction="?handler=Cancel"
                      title="Cancelar desconecta la empresa y vuelve a Selección de IVA">
                Cancelar
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}