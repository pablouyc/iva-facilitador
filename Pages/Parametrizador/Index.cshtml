@page "/Parametrizador"
@model IvaFacilitador.Pages.Parametrizador.IndexModel
@{
    ViewData["Title"] = "Parametrización";
}

<div class="container my-4">
  <div class="card shadow-sm">
    <div class="card-header">
      <div class="h5 mb-0">PARAMETRIZACIÓN @Model.CompanyName</div>
      <small class="text-muted">RealmId: @Model.RealmId</small>
    </div>

    <form method="post" asp-page-handler="Save" class="card-body">
      <input type="hidden" asp-for="RealmId" />

      <div class="mb-3">
        <label class="form-label fw-semibold">Empresa (QBO)</label>
        <input class="form-control" value="@Model.CompanyName" disabled />
      </div>

      <div class="alert alert-info mb-4">
        <div class="fw-semibold">Próximo paso</div>
        Vamos a ir agregando cada sección (Tarifas de ventas, Datáfonos, MEIC/MAG, Prorrata, Cuentas IVA, etc.).
      </div>

      <div class="d-flex justify-content-end gap-2">
        <button type="submit"
                class="btn btn-outline-secondary"
                formaction="?handler=Cancel"
                formmethod="post"
                formnovalidate>
          Cancelar
        </button>

        <button type="submit" class="btn btn-primary">
          Guardar
        </button>
      </div>
    </form>
  </div>
</div>

@section Scripts {
  <partial name="_ValidationScriptsPartial" />
}
