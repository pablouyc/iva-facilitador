@page "/Parametrizador"
@model IvaFacilitador.Pages.Parametrizador.IndexModel
@{
    ViewData["Title"] = "Parametrización";
    var titleName = string.IsNullOrWhiteSpace(Model.CompanyName) ? "—" : Model.CompanyName;
}

<h2 class="mb-3">PARAMETRIZACIÓN @titleName</h2>
<p class="text-muted mb-4">Completa la información para preparar el IVA de Costa Rica.</p>

<form method="post" asp-page-handler="Save" class="card p-3 shadow-sm">
    <input type="hidden" asp-for="RealmId" />
    <div class="mb-3">
        <label class="form-label fw-semibold">Empresa (QBO)</label>
        <input class="form-control" value="@Model.CompanyName" disabled />
        <div class="form-text">RealmId: @Model.RealmId</div>
    </div>

    <!-- Aquí iremos agregando secciones 1..9, paso a paso -->
    <div class="alert alert-info">
        <div class="fw-semibold mb-1">Próximo paso</div>
        Vamos a ir agregando cada sección (Tarifas de ventas, Datáfonos, MEIC/MAG, Prorrata, Cuentas IVA, etc.).
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar</button>
        <a href="/" class="btn btn-outline-secondary">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}